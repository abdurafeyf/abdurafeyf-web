---
import BaseHead from "../../components/BaseHead.astro";
import HeaderUrdu from "../../components/HeaderUrdu.astro";
import Footer from "../../components/Footer.astro";
import ColorScript from "../../components/ColorScript.astro";
import Analytics from "@vercel/analytics/astro";
import { SITE_TITLE_URDU, SITE_DESCRIPTION } from "../../config";

// TODO: Define art pieces with title, image, caption, and category
const artPieces = [
  {
    title: "تجریدی پورٹریٹ",
    image: "/assets/artimages/ASRind.png",
    caption: "اے ایس رند کی 2015 کی ایک نیم تجریدی پینٹنگ۔",
    category: "painting",
  },
];

const categoryColors = {
  calligraphy: "var(--blue)",
  textiles: "var(--green)",
  architecture: "var(--yellow)",
  painting: "var(--red)",
};
---

<!doctype html>
<html lang="ur" dir="rtl">
  <BaseHead title={SITE_TITLE_URDU + " - فن"} description={SITE_DESCRIPTION} />
  <body dir="rtl">
    <HeaderUrdu />
    <main>
      <section class="art-intro">
        <h2>نوادرات کا اشاریہ</h2>
        <p>
          ثقافتی نوادرات اور علاقائی جمالیات کا ایک ڈیجیٹل کیٹلاگ۔ انہیں بغیر
          کسی ظاہری سجاوٹ یا ڈیجیٹل فریم کے پیش کیا گیا ہے تاکہ ہر فن پارے کی
          خالص ساخت، رنگ اور تاریخ ہی مرکزِ توجہ رہے۔
        </p>
      </section>

      <div class="art-grid">
        {
          artPieces.length > 0 ? (
            artPieces.map((piece) => (
              <div class="art-piece">
                <img src={piece.image} alt={piece.title} class="art-image" />
                <div class="art-caption">
                  <span
                    class="category-label"
                    style={`border-bottom: 2px solid ${categoryColors[piece.category] || categoryColors.default}`}
                  >
                    [{piece.category}]
                  </span>
                  <p>{piece.caption}</p>
                </div>
              </div>
            ))
          ) : (
            <p style="grid-column: 1 / -1; text-align: center;">
              ابھی کوئی فن کے نمونے اپ لوڈ نہیں ہوئے۔
            </p>
          )
        }
      </div>
    </main>
    <Footer />
    <ColorScript />
    <Analytics />
  </body>
</html>

<style>
  .art-intro {
    margin-bottom: 2em;
    text-align: center;
  }

  .art-intro h2 {
    font-weight: 400;
    margin-bottom: 0.5em;
  }

  .art-intro p {
    color: var(--gray);
    font-size: 0.95rem;
  }

  .art-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2em;
    margin: 2em 0;
  }

  @media (max-width: 768px) {
    .art-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5em;
    }
  }

  @media (max-width: 480px) {
    .art-grid {
      grid-template-columns: 1fr;
    }
  }

  .art-piece {
    display: flex;
    flex-direction: column;
  }

  .art-image {
    width: 100%;
    display: block;
    margin-bottom: 1em;
    /* Sharp edges, no border-radius */
    /* No drop shadow */
  }

  .art-caption {
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }

  .category-label {
    display: inline-block;
    font-family: "iA Writer Mono", monospace;
    font-weight: 600;
    padding-bottom: 0.2em;
    margin-bottom: 0.5em;
    text-transform: lowercase;
  }

  .art-caption p {
    font-family: "iA Writer Mono", monospace;
    color: var(--black);
    line-height: 1.5;
    margin: 0;
  }

  @media (prefers-color-scheme: dark) {
    .art-caption p {
      color: var(--white);
    }
  }
</style>
